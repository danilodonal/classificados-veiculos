<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Venda seu carro - <%= nome_site %></title>
  <link rel="icon" type="image/svg+xml" href="/images/favicon.svg">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <style>
    :root { --primaria: <%= cor_primaria %>; --secundaria: <%= cor_secundaria %>; --destaque: <%= cor_destaque %>; --fundo: <%= cor_fundo %>; }
    * { font-family: 'Inter', sans-serif; }
    body { background: var(--fundo); }
    .top-bar { background: var(--primaria); color: #fff; font-size: 0.78rem; padding: 6px 0; letter-spacing: 0.3px; }
    .top-bar a { color: #fff; }
    .navbar-custom { background: var(--secundaria); padding: 12px 0; box-shadow: 0 2px 20px rgba(0,0,0,0.08); }
    .navbar-nav .nav-link { color: rgba(255,255,255,0.75); font-size: 0.88rem; padding: 0.3rem 0.7rem !important; border-radius: 8px; font-weight: 500; transition: opacity .2s; }
    .navbar-nav .nav-link:hover, .navbar-nav .nav-link.active { color: #fff; background: rgba(255,255,255,0.1); }
    .page-header { background: linear-gradient(160deg, var(--secundaria) 0%, #1a2744 50%, var(--primaria) 100%); padding: 2.5rem 0; color: #fff; }
    .page-header h1 { font-size: 1.8rem; font-weight: 800; }
    .form-box { background: #fff; border-radius: 16px; padding: 2rem; box-shadow: 0 4px 24px rgba(0,0,0,0.06); max-width: 640px; margin: 0 auto; }
    .steps { display: flex; gap: 1rem; margin-bottom: 2rem; }
    .step { flex: 1; text-align: center; padding: 0.8rem; border-radius: 12px; background: #f0f2f5; font-size: 0.85rem; font-weight: 600; color: #888; }
    .step.active { background: #e8f4fd; color: #0d6efd; }
    .step i { font-size: 1.2rem; display: block; margin-bottom: 4px; }
    footer { background: var(--secundaria); padding: 3rem 0 2rem !important; }
    footer small { opacity: .7; }
  </style>
</head>
<body>
  <%- include('partials/topbar') %>
  <nav class="navbar navbar-expand-md navbar-dark navbar-custom">
    <div class="container">
      <a class="navbar-brand fw-bold" href="/"><img src="/images/car-logo.svg" alt="" style="height:28px;width:28px" class="me-1"> <%= nome_site %></a>
      <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target="#menuNav">
        <span class="navbar-toggler-icon"></span>
      </button>
      <div class="collapse navbar-collapse" id="menuNav">
        <ul class="navbar-nav ms-auto">
          <li class="nav-item"><a class="nav-link" href="/ofertas">Ofertas</a></li>
          <li class="nav-item"><a class="nav-link" href="/">Estoque</a></li>
          <li class="nav-item"><a class="nav-link active" href="/vender">Venda seu carro</a></li>
          <li class="nav-item"><a class="nav-link" href="/financie">Financie</a></li>
          <li class="nav-item"><a class="nav-link" href="/sobre">Sobre</a></li>
        </ul>
        
      </div>
    </div>
  </nav>

  <div class="page-header">
    <div class="container">
      <h1><i class="bi bi-cash-coin me-2"></i>Venda seu carro</h1>
      <p class="mb-0 opacity-75">Faça uma avaliação e receba a melhor proposta</p>
    </div>
  </div>

  <div class="container my-4">
    <div class="steps">
      <div class="step active"><i class="bi bi-chat-dots"></i> Preencha os dados</div>
      <div class="step"><i class="bi bi-search"></i> Avaliamos</div>
      <div class="step"><i class="bi bi-hand-thumbs-up"></i> Receba proposta</div>
    </div>

    <div class="form-box">
      <% if (erro) { %>
        <div class="alert alert-danger"><%= erro %></div>
      <% } %>
      <form method="POST">
        <div class="row g-3">
          <div class="col-md-6">
            <label class="form-label">Nome *</label>
            <input type="text" name="nome" class="form-control" required>
          </div>
          <div class="col-md-6">
            <label class="form-label">Telefone *</label>
            <input type="tel" name="telefone" class="form-control" required placeholder="(11) 99999-9999">
          </div>
          <div class="col-md-6">
            <label class="form-label">E-mail</label>
            <input type="email" name="email" class="form-control">
          </div>
          <div class="col-md-6">
            <label class="form-label">Marca</label>
            <input type="text" name="marca" class="form-control" placeholder="Ex: Volkswagen">
          </div>
          <div class="col-md-6">
            <label class="form-label">Modelo</label>
            <input type="text" name="modelo" class="form-control" placeholder="Ex: Gol">
          </div>
          <div class="col-md-6">
            <label class="form-label">Ano</label>
            <input type="number" name="ano" class="form-control" placeholder="2020">
          </div>
          <div class="col-12">
            <label class="form-label">Mensagem</label>
            <textarea name="mensagem" class="form-control" rows="3" placeholder="Conte mais sobre o veículo..."></textarea>
          </div>
          <div class="col-12">
            <button type="submit" class="btn btn-success w-100 py-2"><i class="bi bi-whatsapp me-2"></i>Enviar via WhatsApp</button>
          </div>
        </div>
      </form>
    </div>
  </div>

  <footer class="text-white text-center py-4 mt-4">
    <small>&copy; <%= new Date().getFullYear() %> <%= nome_site %>. Todos os direitos reservados.</small>
  </footer>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
