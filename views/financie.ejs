<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Financie - AutoClassificados</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <style>
    :root { --primaria: <%= cor_primaria %>; --secundaria: <%= cor_secundaria %>; --destaque: <%= cor_destaque %>; --fundo: <%= cor_fundo %>; }
    * { font-family: 'Inter', sans-serif; }
    body { background: var(--fundo); }
    .top-bar { background: var(--primaria); color: #fff; font-size: 0.78rem; padding: 6px 0; }
    .top-bar a { color: #fff; }
    .navbar-custom { background: var(--secundaria); padding: 12px 0; }
    .navbar-nav .nav-link { color: rgba(255,255,255,0.75); font-size: 0.88rem; padding: 0.3rem 0.7rem !important; border-radius: 8px; }
    .navbar-nav .nav-link:hover, .navbar-nav .nav-link.active { color: #fff; background: rgba(255,255,255,0.1); }
    .page-header { background: linear-gradient(135deg, var(--secundaria) 0%, #16213e 50%, var(--primaria) 100%); padding: 2.5rem 0; color: #fff; }
    .page-header h1 { font-size: 1.8rem; font-weight: 800; }
    .card-beneficio { background: #fff; border-radius: 16px; padding: 1.5rem; box-shadow: 0 4px 20px rgba(0,0,0,0.06); height: 100%; transition: transform .25s ease; }
    .card-beneficio:hover { transform: translateY(-4px); }
    .card-beneficio .icon { font-size: 2rem; color: var(--primaria); }
    .card-beneficio h5 { font-weight: 700; font-size: 1rem; margin: 0.8rem 0 0.4rem; }
    .card-beneficio p { font-size: 0.88rem; color: #666; margin: 0; }
    .simulacao-box { background: #fff; border-radius: 16px; padding: 2rem; box-shadow: 0 4px 20px rgba(0,0,0,0.06); max-width: 600px; margin: 0 auto; }
    .section-title { font-size: 1.3rem; font-weight: 700; color: var(--secundaria); margin-bottom: 1.2rem; padding-bottom: 0.6rem; border-bottom: 3px solid var(--destaque); display: inline-block; }
    footer { background: var(--secundaria); }
  </style>
</head>
<body>
  <%- include('partials/topbar') %>
  <nav class="navbar navbar-expand-md navbar-dark navbar-custom">
    <div class="container">
      <a class="navbar-brand fw-bold" href="/"><i class="bi bi-car-front-fill me-1"></i> AutoClassificados</a>
      <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target="#menuNav">
        <span class="navbar-toggler-icon"></span>
      </button>
      <div class="collapse navbar-collapse" id="menuNav">
        <ul class="navbar-nav ms-auto">
          <li class="nav-item"><a class="nav-link" href="/ofertas">Ofertas</a></li>
          <li class="nav-item"><a class="nav-link" href="/">Estoque</a></li>
          <li class="nav-item"><a class="nav-link" href="/vender">Venda seu carro</a></li>
          <li class="nav-item"><a class="nav-link active" href="/financie">Financie</a></li>
          <li class="nav-item"><a class="nav-link" href="/sobre">Sobre</a></li>
        </ul>
        
      </div>
    </div>
  </nav>

  <div class="page-header">
    <div class="container">
      <h1><i class="bi bi-bank me-2"></i>Financiamento</h1>
      <p class="mb-0 opacity-75">Realize o sonho do carro próprio com as melhores taxas</p>
    </div>
  </div>

  <div class="container my-4">
    <div class="row g-3 mb-4">
      <div class="col-md-4">
        <div class="card-beneficio text-center">
          <div class="icon"><i class="bi bi-percent"></i></div>
          <h5>Taxas imperdíveis</h5>
          <p>As menores taxas do mercado, parcelas que cabem no seu bolso.</p>
        </div>
      </div>
      <div class="col-md-4">
        <div class="card-beneficio text-center">
          <div class="icon"><i class="bi bi-clock-history"></i></div>
          <h5>Aprovação rápida</h5>
          <p>Crédito aprovado em até 24 horas com toda segurança.</p>
        </div>
      </div>
      <div class="col-md-4">
        <div class="card-beneficio text-center">
          <div class="icon"><i class="bi bi-file-earmark-text"></i></div>
          <h5>Sem burocracia</h5>
          <p>Processo 100% digital, análise simplificada e rápida.</p>
        </div>
      </div>
    </div>

    <h2 class="section-title">Simule seu financiamento</h2>
    <div class="simulacao-box mt-3">
      <p class="text-muted mb-3">Preencha seus dados e entraremos em contato com uma simulação personalizada.</p>
      <form method="GET" action="https://wa.me/<%= whatsapp %>">
        <div class="row g-3">
          <div class="col-md-6">
            <label class="form-label">Valor do veículo</label>
            <input type="text" class="form-control" placeholder="R$ 50.000" id="valor">
          </div>
          <div class="col-md-6">
            <label class="form-label">Entrada</label>
            <input type="text" class="form-control" placeholder="R$ 10.000" id="entrada">
          </div>
          <div class="col-md-6">
            <label class="form-label">Prazo (meses)</label>
            <select class="form-select">
              <option>24 meses</option>
              <option selected>36 meses</option>
              <option>48 meses</option>
              <option>60 meses</option>
            </select>
          </div>
          <div class="col-md-6">
            <label class="form-label">Seu nome</label>
            <input type="text" class="form-control" placeholder="Seu nome" id="nomeSimulacao">
          </div>
          <div class="col-12">
            <button type="submit" class="btn btn-success w-100 py-2">
              <i class="bi bi-whatsapp me-2"></i>Falar com consultor
            </button>
          </div>
        </div>
      </form>
    </div>
  </div>

  <footer class="text-white text-center py-4 mt-4">
    <small>&copy; 2026 AutoClassificados. Todos os direitos reservados.</small>
  </footer>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
