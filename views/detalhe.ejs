<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= veiculo.marca %> <%= veiculo.modelo %> - AutoClassificados</title>
  <link rel="icon" type="image/svg+xml" href="/images/favicon.svg">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <style>
    * { font-family: 'Inter', sans-serif; }
    body { background: var(--fundo); }
    :root { --primaria: <%= cor_primaria %>; --secundaria: <%= cor_secundaria %>; --destaque: <%= cor_destaque %>; --fundo: <%= cor_fundo %>; }
    .top-bar { background: var(--primaria); color: #fff; font-size: 0.78rem; padding: 6px 0; }
    .navbar-custom { background: var(--secundaria); padding: 12px 0; }
    .gallery-wrapper { background: #fff; border-radius: 16px; overflow: hidden; box-shadow: 0 4px 20px rgba(0,0,0,0.06); }
    .gallery-wrapper .carousel-item img { width: 100%; height: 460px; object-fit: cover; }
    .carousel-indicators { position: static; margin: 0; padding: 10px; gap: 6px; background: var(--fundo); }
    .carousel-indicators button { width: 60px !important; height: 45px !important; border-radius: 6px; overflow: hidden; text-indent: 0; border: 2px solid transparent; opacity: 0.6; background: none; padding: 0; }
    .carousel-indicators button.active { opacity: 1; border-color: var(--destaque); }
    .carousel-indicators button img { width: 100%; height: 100%; object-fit: cover; display: block; }
    .carousel-control-prev-icon, .carousel-control-next-icon { background-color: rgba(0,0,0,0.4); border-radius: 50%; padding: 20px; background-size: 50%; }
    .info-card { background: #fff; border-radius: 16px; padding: 1.5rem; box-shadow: 0 4px 20px rgba(0,0,0,0.06); }
    .info-card h1 { font-size: 1.4rem; font-weight: 800; color: var(--secundaria); }
    .preco-detalhe { font-size: 2rem; font-weight: 800; color: var(--primaria); }
    .info-grid { display: grid; grid-template-columns: 1fr; gap: 10px; }
    .info-item { background: var(--fundo); border-radius: 10px; padding: 10px 14px; }
    .info-item .label { font-size: 0.7rem; color: #888; text-transform: uppercase; letter-spacing: 0.5px; font-weight: 600; }
    .info-item .value { font-size: 0.95rem; font-weight: 700; color: var(--secundaria); margin-top: 2px; }
    .badge-vendido-top { position: absolute; top: 16px; left: 16px; z-index: 5; background: #dc3545; color: #fff; font-weight: 700; padding: 6px 18px; border-radius: 30px; font-size: 0.85rem; }
    .btn-whatsapp { background: #25d366; border: none; color: #fff; font-weight: 700; padding: 14px; border-radius: 12px; font-size: 1rem; }
    .btn-whatsapp:hover { background: #1ebe5d; color: #fff; }
    .desc-box { background: #fff; border-radius: 16px; padding: 1.5rem; box-shadow: 0 4px 20px rgba(0,0,0,0.06); margin-top: 1.5rem; }
    .desc-box h5 { font-weight: 700; color: var(--secundaria); margin-bottom: 0.8rem; }
    .desc-box p { font-size: 0.92rem; color: #555; line-height: 1.7; margin: 0; }
    @media (max-width: 576px) {
      .gallery-wrapper .carousel-item img { height: 280px; }
      .carousel-indicators button { width: 50px !important; height: 38px !important; }
      .info-card { padding: 1rem; }
      .info-card h1 { font-size: 1.15rem; }
      .preco-detalhe { font-size: 1.5rem; }
      .info-item { padding: 8px 12px; }
      .info-item .value { font-size: 0.85rem; }
    }
  </style>
</head>
<body>
  <%- include('partials/topbar') %>
  <nav class="navbar navbar-expand-md navbar-dark navbar-custom">
    <div class="container">
      <a class="navbar-brand fw-bold" href="/"><img src="/images/car-logo.svg" alt="" style="height:28px;width:28px" class="me-1"> AutoClassificados</a>
      <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target="#menuNav">
        <span class="navbar-toggler-icon"></span>
      </button>
      <div class="collapse navbar-collapse" id="menuNav">
        <ul class="navbar-nav ms-auto">
          <li class="nav-item"><a class="nav-link" href="/ofertas">Ofertas</a></li>
          <li class="nav-item"><a class="nav-link" href="/">Estoque</a></li>
          <li class="nav-item"><a class="nav-link" href="/vender">Venda seu carro</a></li>
          <li class="nav-item"><a class="nav-link" href="/financie">Financie</a></li>
          <li class="nav-item"><a class="nav-link" href="/sobre">Sobre</a></li>
        </ul>
        <a href="/" class="btn btn-outline-light btn-sm rounded-pill px-3"><i class="bi bi-arrow-left me-1"></i> Voltar</a>
      </div>
    </div>
  </nav>

  <div class="container my-4">

    <div class="row g-4">
      <div class="col-lg-7">
        <% const imgs = parseImagens(veiculo) %>
        <div class="gallery-wrapper position-relative">
          <% if (veiculo.vendido) { %>
            <span class="badge-vendido-top"><i class="bi bi-x-circle-fill me-1"></i>VENDIDO</span>
          <% } %>

          <div id="carroGaleria" class="carousel slide" data-bs-ride="carousel" data-bs-interval="2000">
            <div class="carousel-inner">
              <% if (imgs.length === 0) { %>
                <div class="carousel-item active">
                  <img src="https://placehold.co/800x500/e9ecef/999?text=Sem+Imagem" alt="Sem imagem">
                </div>
              <% } else { %>
                <% imgs.forEach((img, i) => { %>
                  <div class="carousel-item <%= i === 0 ? 'active' : '' %>">
                    <img src="<%= img %>" alt="Foto <%= i + 1 %> do <%= veiculo.marca %> <%= veiculo.modelo %>">
                  </div>
                <% }) %>
              <% } %>
            </div>

            <% if (imgs.length > 1) { %>
              <button class="carousel-control-prev" type="button" data-bs-target="#carroGaleria" data-bs-slide="prev">
                <span class="carousel-control-prev-icon"></span>
              </button>
              <button class="carousel-control-next" type="button" data-bs-target="#carroGaleria" data-bs-slide="next">
                <span class="carousel-control-next-icon"></span>
              </button>

              <div class="carousel-indicators">
                <% imgs.forEach((img, i) => { %>
                  <button type="button" data-bs-target="#carroGaleria" data-bs-slide-to="<%= i %>" class="<%= i === 0 ? 'active' : '' %>">
                    <img src="<%= img %>" alt="Miniatura <%= i + 1 %>">
                  </button>
                <% }) %>
              </div>
            <% } %>
          </div>
        </div>
        <% if (veiculo.video_url) { %>
          <div class="mt-4">
            <h5 class="section-title"><i class="bi bi-play-circle-fill me-2" style="color:var(--destaque)"></i>Vídeo do Anúncio</h5>
            <div class="ratio ratio-16x9 rounded-4 overflow-hidden" style="box-shadow:0 4px 20px rgba(0,0,0,0.08)">
              <iframe src="<%= veiculo.video_url.replace('watch?v=', 'embed/').replace('youtu.be/', 'youtube.com/embed/').split('&')[0] %>" allowfullscreen loading="lazy"></iframe>
            </div>
          </div>
        <% } %>
      </div>
      <div class="col-lg-5">
        <div class="info-card">
          <% if (veiculo.vendido) { %>
            <div class="alert alert-danger py-2 px-3 mb-3"><i class="bi bi-x-circle-fill me-1"></i> Este veículo já foi vendido.</div>
          <% } %>
          <div class="d-flex align-items-center gap-2 mb-1">
            <% if (veiculo.destaque) { %>
              <span class="badge bg-warning text-dark rounded-pill"><i class="bi bi-star-fill me-1"></i>Destaque</span>
            <% } %>
          </div>
          <h1><%= veiculo.marca %> <%= veiculo.modelo %></h1>
          <div class="preco-detalhe">R$ <%= veiculo.preco.toLocaleString('pt-BR', { minimumFractionDigits: 2 }) %></div>

          <div class="info-grid mt-3">
            <div class="info-item">
              <div class="label"><i class="bi bi-calendar me-1"></i>Ano</div>
              <div class="value"><%= veiculo.ano_fabricacao %>/<%= veiculo.ano_modelo %></div>
            </div>
            <div class="info-item">
              <div class="label"><i class="bi bi-speedometer2 me-1"></i>Quilometragem</div>
              <div class="value"><%= veiculo.quilometragem.toLocaleString() %> km</div>
            </div>
            <div class="info-item">
              <div class="label"><i class="bi bi-fuel-pump me-1"></i>Combustível</div>
              <div class="value"><%= veiculo.combustivel %></div>
            </div>
            <div class="info-item">
              <div class="label"><i class="bi bi-gear me-1"></i>Câmbio</div>
              <div class="value"><%= veiculo.cambio %></div>
            </div>
            <div class="info-item">
              <div class="label"><i class="bi bi-palette me-1"></i>Cor</div>
              <div class="value"><%= veiculo.cor %></div>
            </div>
            <div class="info-item">
              <div class="label"><i class="bi bi-car-front me-1"></i>Portas</div>
              <div class="value"><%= veiculo.portas %></div>
            </div>
          </div>

          <div class="d-grid mt-4">
            <a href="https://wa.me/<%= whatsapp %>?text=Olá! Tenho interesse no <%= veiculo.marca %> <%= veiculo.modelo %> (<%= veiculo.ano_fabricacao %>/<%= veiculo.ano_modelo %>) - R$ <%= veiculo.preco.toLocaleString('pt-BR', { minimumFractionDigits: 2 }) %>" target="_blank" class="btn btn-whatsapp">
              <i class="bi bi-whatsapp me-2"></i> Fale Conosco pelo WhatsApp
            </a>
          </div>
        </div>

        <% if (veiculo.descricao) { %>
          <div class="desc-box">
            <h5><i class="bi bi-file-text me-1"></i> Descrição</h5>
            <p><%= veiculo.descricao %></p>
          </div>
        <% } %>
      </div>
    </div>
  </div>

  <footer class="text-white text-center py-4 mt-4" style="background: var(--secundaria);">
    <small>&copy; 2026 AutoClassificados. Todos os direitos reservados.</small>
  </footer>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
