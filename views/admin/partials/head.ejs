<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <script>if(localStorage.getItem('admin-theme')==='dark')document.documentElement.classList.add('dark-mode')</script>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= titulo %> - Painel Admin</title>
  <link rel="icon" type="image/svg+xml" href="/images/favicon.svg">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <style>
    * { font-family: 'Inter', sans-serif; }
    body { background: #f0f2f5; }
    .dark-mode { --bg-body: #0f1923; --bg-card: #1a2634; --bg-sidebar: #1a2634; --bg-topbar: #1a2634; --text: #e0e0e0; --text-muted: #9aa6b5; --border: #2a3648; }
    .dark-mode body { background: var(--bg-body); color: var(--text); }
    .dark-mode .admin-topbar { background: var(--bg-topbar); border-color: var(--border); }
    .dark-mode .admin-topbar .brand { color: #fff; }
    .dark-mode .admin-sidebar { background: var(--bg-sidebar); border-color: var(--border); }
    .dark-mode .admin-sidebar .nav-link { color: #bbb; }
    .dark-mode .admin-sidebar .nav-link:hover { background: #24303e; color: #fff; }
    .dark-mode .admin-sidebar .nav-link.active { background: #e94560; }
    .dark-mode .admin-content { background: var(--bg-body); }
    .dark-mode .card-admin { background: var(--bg-card); box-shadow: 0 1px 4px rgba(0,0,0,0.2); }
    .dark-mode .card-admin-body { background: var(--bg-card); }
    .dark-mode .page-title { color: #fff; }
    .dark-mode .table { color: var(--text); }
    .dark-mode .table-light { background: var(--bg-card) !important; }
    .dark-mode .table-light th { background: var(--bg-card) !important; color: #fff; border-color: var(--border); }
    .dark-mode .table-striped > tbody > tr:nth-of-type(odd) { background: #1e2a3a; }
    .dark-mode .table-hover > tbody > tr:hover { background: #24303e; }
    .dark-mode .table-warning { background: #3a4a1a !important; }
    .dark-mode .table-warning td { color: #000 !important; font-weight: 500; }
    .dark-mode .table-warning .badge.bg-warning { background: #f0c040 !important; color: #1a1a1a !important; }
    .dark-mode .table td, .dark-mode .table th { border-color: var(--border); }
    .dark-mode .text-muted { color: var(--text-muted) !important; }
    .dark-mode .form-control, .dark-mode .form-select { background: #0f1923; color: var(--text); border-color: var(--border); }
    .dark-mode .form-control:focus, .dark-mode .form-select:focus { background: #0f1923; color: var(--text); }
    .dark-mode .form-check-label { color: var(--text); }
    .dark-mode .offcanvas { background: var(--bg-card); color: var(--text); }
    .dark-mode .offcanvas .btn-close { filter: invert(1); }
    .dark-mode .offcanvas .btn-light { background: #24303e; color: var(--text); border-color: var(--border); }
    .dark-mode .offcanvas .btn-light.bg-danger { background: #e94560 !important; color: #fff !important; }
    .dark-mode .alert { background: #24303e; color: var(--text); border-color: var(--border); }
    .dark-mode .alert-danger { background: #3a1a1a; border-color: #5a2a2a; color: #ff8a8a; }
    .dark-mode .alert-success { background: #1a3a1a; border-color: #2a5a2a; color: #8aff8a; }
    .admin-topbar { background: #fff; border-bottom: 1px solid #e9ecef; padding: 10px 0; position: sticky; top: 0; z-index: 1030; }
    .admin-topbar .brand { font-weight: 800; font-size: 1.15rem; color: #1a1a2e; text-decoration: none; }
    .admin-topbar .brand i { color: #e94560; }
    .admin-sidebar { background: #fff; border-right: 1px solid #e9ecef; min-height: calc(100vh - 57px); padding: 16px 0; }
    .admin-sidebar .nav-link { color: #555; padding: 10px 20px; font-size: 0.88rem; font-weight: 500; border-radius: 0; display: flex; align-items: center; gap: 10px; transition: all .15s; }
    .admin-sidebar .nav-link:hover { background: #f0f2f5; color: #1a1a2e; }
    .admin-sidebar .nav-link.active { background: #e94560; color: #fff; font-weight: 600; }
    .admin-sidebar .nav-link i { font-size: 1.1rem; width: 20px; text-align: center; }
    .admin-content { padding: 20px 24px; }
    .card-admin { border: none; border-radius: 14px; box-shadow: 0 1px 4px rgba(0,0,0,0.04); background: #fff; }
    .card-admin-body { padding: 1.2rem; }
    .stat-card { border-radius: 14px; border: none; padding: 1.2rem; color: #fff; }
    .stat-card .icon { font-size: 2rem; opacity: 0.3; }
    .stat-card .number { font-size: 1.6rem; font-weight: 800; }
    .stat-card .label { font-size: 0.8rem; opacity: 0.8; }
    .page-title { font-size: 1.15rem; font-weight: 700; color: #1a1a2e; margin-bottom: 1rem; }
    @media (max-width: 767px) {
      .table-mobile-cards thead { display: none; }
      .table-mobile-cards tr { display: block; background: #fff; border-radius: 12px; padding: 12px; margin-bottom: 10px; border: 1px solid #e9ecef; }
      .table-mobile-cards td { display: block; padding: 4px 8px !important; border: none; text-align: right; }
      .table-mobile-cards td::before { content: attr(data-label); float: left; font-weight: 600; color: #666; font-size: 0.82rem; }
      .table-mobile-cards td:first-child { text-align: center; }
      .table-mobile-cards td:first-child::before { display: none; }
      .dark-mode .table-mobile-cards tr { background: var(--bg-card); border-color: var(--border); }
      .dark-mode .table-mobile-cards td::before { color: var(--text-muted); }
    }
    @media (max-width: 767px) {
      .admin-sidebar { display: none; }
      .admin-content { padding: 16px; }
      .admin-topbar .brand { font-size: 1rem; }
    }
    @media (min-width: 768px) {
      .offcanvas-start { display: none !important; }
    }
    <% if (typeof css !== 'undefined') { %><%= css %><% } %>
  </style>
</head>
<body>
  <nav class="admin-topbar">
    <div class="container-fluid px-3 px-md-4">
      <div class="d-flex justify-content-between align-items-center">
        <div class="d-flex align-items-center gap-3">
          <button class="btn d-md-none p-0 border-0 fs-5" type="button" data-bs-toggle="offcanvas" data-bs-target="#sidebarCanvas"><i class="bi bi-list"></i></button>
          <a href="/admin" class="brand"><img src="/images/car-logo.svg" alt="" style="height:24px;width:24px" class="me-1"> AutoClassificados</a>
          <span class="badge bg-dark d-none d-md-inline fs-6 fw-normal px-3 py-1 rounded-pill"><%= titulo %></span>
        </div>
        <div class="d-flex gap-2 align-items-center">
          <a href="/" class="btn btn-outline-secondary btn-sm rounded-pill px-3" target="_blank"><i class="bi bi-eye"></i> <span class="d-none d-md-inline">Site</span></a>
          <a href="/admin/config" class="btn btn-outline-secondary btn-sm rounded-pill px-3"><i class="bi bi-gear"></i> <span class="d-none d-md-inline">Config</span></a>
          <button id="darkToggle" class="btn btn-outline-secondary btn-sm rounded-pill px-3" title="Alternar tema"><i class="bi bi-moon-fill"></i></button>
          <a href="/admin/logout" class="btn btn-outline-danger btn-sm rounded-pill px-3"><i class="bi bi-box-arrow-right"></i> <span class="d-none d-md-inline">Sair</span></a>
        </div>
      </div>
    </div>
  </nav>

  <div class="offcanvas offcanvas-start d-md-none" tabindex="-1" id="sidebarCanvas">
    <div class="offcanvas-header border-bottom">
      <span class="fw-bold fs-5"><img src="/images/car-logo.svg" alt="" style="height:24px;width:24px" class="me-1"> Admin</span>
      <button type="button" class="btn-close" data-bs-dismiss="offcanvas"></button>
    </div>
    <div class="offcanvas-body p-0">
      <nav class="d-flex flex-column gap-1 p-3">
        <a href="/admin" class="btn btn-light text-start d-flex align-items-center gap-3 py-2 px-3 rounded-3 <%= pagina === 'dashboard' ? 'bg-danger text-white' : '' %>"><i class="bi bi-speedometer2 fs-5"></i> Dashboard</a>
        <a href="/admin/vendas" class="btn btn-light text-start d-flex align-items-center gap-3 py-2 px-3 rounded-3 <%= pagina === 'vendas' ? 'bg-danger text-white' : '' %>"><i class="bi bi-cart-check fs-5"></i> Vendas</a>
        <a href="/admin/vendedores" class="btn btn-light text-start d-flex align-items-center gap-3 py-2 px-3 rounded-3 <%= pagina === 'vendedores' ? 'bg-danger text-white' : '' %>"><i class="bi bi-people fs-5"></i> Vendedores</a>
        <a href="/admin/analytics?periodo=mes" class="btn btn-light text-start d-flex align-items-center gap-3 py-2 px-3 rounded-3 <%= pagina === 'analytics' ? 'bg-danger text-white' : '' %>"><i class="bi bi-graph-up fs-5"></i> Análises</a>
        <hr>
        <a href="/admin/usuarios" class="btn btn-light text-start d-flex align-items-center gap-3 py-2 px-3 rounded-3 <%= pagina === 'usuarios' ? 'bg-danger text-white' : '' %>"><i class="bi bi-shield-lock fs-5"></i> Usuários</a>
        <hr>
        <a href="/" class="btn btn-light text-start d-flex align-items-center gap-3 py-2 px-3 rounded-3"><i class="bi bi-eye fs-5"></i> Ver site</a>
        <a href="/admin/config" class="btn btn-light text-start d-flex align-items-center gap-3 py-2 px-3 rounded-3"><i class="bi bi-gear fs-5"></i> Configurações</a>
        <a href="/admin/logout" class="btn btn-light text-start d-flex align-items-center gap-3 py-2 px-3 rounded-3 text-danger"><i class="bi bi-box-arrow-right fs-5"></i> Sair</a>
      </nav>
    </div>
  </div>

  <div class="container-fluid">
    <div class="row">
      <div class="col-auto d-none d-md-block p-0">
        <div class="admin-sidebar">
          <nav class="d-flex flex-column gap-1">
            <a href="/admin" class="nav-link <%= pagina === 'dashboard' ? 'active' : '' %>"><i class="bi bi-speedometer2"></i> Dashboard</a>
            <a href="/admin/vendas" class="nav-link <%= pagina === 'vendas' ? 'active' : '' %>"><i class="bi bi-cart-check"></i> Vendas</a>
            <a href="/admin/vendedores" class="nav-link <%= pagina === 'vendedores' ? 'active' : '' %>"><i class="bi bi-people"></i> Vendedores</a>
            <a href="/admin/analytics?periodo=mes" class="nav-link <%= pagina === 'analytics' ? 'active' : '' %>"><i class="bi bi-graph-up"></i> Análises</a>
            <hr class="my-1">
            <a href="/admin/usuarios" class="nav-link <%= pagina === 'usuarios' ? 'active' : '' %>"><i class="bi bi-shield-lock"></i> Usuários</a>
            <a href="/admin/config" class="nav-link"><i class="bi bi-gear"></i> Config</a>
          </nav>
        </div>
      </div>
      <div class="col p-0">
        <div class="admin-content">
