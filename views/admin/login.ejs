<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Login - Painel Admin</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <style>
    * { font-family: 'Inter', sans-serif; }
    body { background: linear-gradient(135deg, #1a1a2e 0%, #16213e 50%, #0f3460 100%); height: 100vh; display: flex; align-items: center; }
    .login-card { max-width: 400px; margin: 0 auto; border: none; border-radius: 16px; }
  </style>
</head>
<body>
  <div class="container">
    <div class="card login-card shadow-lg">
      <div class="card-body p-4 p-md-5">
        <div class="text-center mb-4">
          <div class="fs-1 text-danger mb-2"><i class="bi bi-shield-lock"></i></div>
          <h4 class="fw-bold">Painel Administrativo</h4>
          <p class="text-muted small">Faça login para continuar</p>
        </div>
        <% if (erro) { %>
          <div class="alert alert-danger py-2"><i class="bi bi-exclamation-triangle me-1"></i> <%= erro %></div>
        <% } %>
        <form method="POST">
          <div class="mb-3">
            <label class="form-label small fw-medium">Usuário</label>
            <input type="text" name="username" class="form-control form-control-lg" placeholder="Digite seu usuário" required>
          </div>
          <div class="mb-4">
            <label class="form-label small fw-medium">Senha</label>
            <input type="password" name="password" class="form-control form-control-lg" placeholder="Digite sua senha" required>
          </div>
          <button type="submit" class="btn btn-danger btn-lg w-100 fw-bold"><i class="bi bi-box-arrow-in-right me-2"></i> Entrar</button>
        </form>
        <div class="text-center mt-4">
          <a href="/" class="text-decoration-none small"><i class="bi bi-arrow-left"></i> Voltar ao site</a>
        </div>
      </div>
    </div>
  </div>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
