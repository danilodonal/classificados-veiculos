<%- include('partials/head', { titulo: usuario ? 'Editar Usuário' : 'Novo Usuário', pagina: 'usuarios' }) %>
<div class="d-flex justify-content-between align-items-center mb-3">
  <h1 class="page-title mb-0"><%= usuario ? 'Editar Usuário' : 'Novo Usuário' %></h1>
  <a href="/admin/usuarios" class="btn btn-outline-secondary btn-sm rounded-pill px-3"><i class="bi bi-arrow-left"></i> Voltar</a>
</div>
<% if (erro) { %><div class="alert alert-danger"><%= erro %></div><% } %>
<div class="card-admin">
  <div class="card-admin-body">
    <form method="POST" action="<%= usuario ? '/admin/usuarios/editar/' + usuario.id : '/admin/usuarios/novo' %>">
      <div class="row g-3">
        <div class="col-md-6">
          <label class="form-label small fw-semibold">Nome</label>
          <input type="text" name="nome" class="form-control" value="<%= usuario ? usuario.nome : '' %>" placeholder="Nome completo">
        </div>
        <div class="col-md-6">
          <label class="form-label small fw-semibold">Username *</label>
          <input type="text" name="username" class="form-control" value="<%= usuario ? usuario.username : '' %>" required>
        </div>
        <div class="col-md-6">
          <label class="form-label small fw-semibold"><%= usuario ? 'Nova senha (deixe vazio para manter)' : 'Senha *' %></label>
          <input type="password" name="password" class="form-control" <%= usuario ? '' : 'required' %>>
        </div>
      </div>
      <div class="mt-4">
        <button type="submit" class="btn btn-danger rounded-pill px-4"><i class="bi bi-check-lg"></i> Salvar</button>
      </div>
    </form>
  </div>
</div>
<%- include('partials/foot') %>