<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= nome_site %></title>
  <link rel="icon" type="image/svg+xml" href="/images/favicon.svg">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <style>
    * { font-family: 'Inter', sans-serif; }
    :root { --primaria: <%= cor_primaria %>; --secundaria: <%= cor_secundaria %>; --destaque: <%= cor_destaque %>; --fundo: <%= cor_fundo %>; }
    body { background: var(--fundo); }
    .top-bar { background: var(--primaria); color: #fff; font-size: 0.78rem; padding: 6px 0; }
    .navbar-custom { background: var(--secundaria); padding: 12px 0; }
    .hero { background: linear-gradient(135deg, var(--secundaria) 0%, #16213e 50%, var(--primaria) 100%); padding: 3.5rem 0 3rem; margin-bottom: 2rem; position: relative; overflow: hidden; }
    .hero::before { content: ''; position: absolute; top: -50%; right: -20%; width: 500px; height: 500px; border-radius: 50%; background: rgba(255,255,255,0.03); }
    .hero::after { content: ''; position: absolute; bottom: -30%; left: -10%; width: 300px; height: 300px; border-radius: 50%; background: rgba(255,255,255,0.02); }
    .hero h1 { font-size: 2.2rem; font-weight: 800; letter-spacing: -0.5px; color: #fff; }
    .hero .lead { font-size: 1.05rem; color: #fff; }
    .hero .form-control, .hero .form-select { border-radius: 10px; border: none; padding: 10px 16px; font-size: 0.9rem; }
    .hero .btn-search { border-radius: 10px; padding: 10px 20px; font-weight: 600; background: var(--destaque); border: none; color: #fff; }
    .hero .btn-search:hover { background: #d63851; }
    .card { border: none; border-radius: 14px; overflow: hidden; transition: transform .25s ease, box-shadow .25s ease; background: #fff; }
    .card:hover { transform: translateY(-5px); box-shadow: 0 12px 35px rgba(0,0,0,0.1); }
    .card-img-top { height: 220px; object-fit: cover; }
    .card-body { padding: 1.2rem 1.2rem; }
    .card-title { font-size: 1.05rem; font-weight: 700; margin-bottom: 0.4rem; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .card-meta { font-size: 0.82rem; color: #6c757d; line-height: 1.6; }
    .card-meta i { margin-right: 3px; }
    .preco { font-size: 1.3rem; font-weight: 800; color: var(--primaria); margin: 0.4rem 0 0.5rem; }
    .tag-group { display: flex; gap: 4px; flex-wrap: wrap; }
    .tag { font-size: 0.68rem; padding: 2px 8px; border-radius: 20px; background: #f0f2f5; color: #444; font-weight: 500; }
    .tag-cambio { background: #e8f4fd; color: #0d6efd; }
    .tag-cor { background: #f0fdf4; color: #16a34a; }
    .tag-portas { background: #fef3c7; color: #b45309; }
    .card-footer { background: transparent; border-top: 1px solid #f0f0f0; padding: 0.7rem 1.1rem; }
    .card-footer .btn { border-radius: 10px; font-size: 0.82rem; font-weight: 600; padding: 7px 0; }
    .badge-destaque { position: absolute; top: 10px; left: 10px; background: linear-gradient(135deg, #f59e0b, #d97706); color: #fff; font-size: 0.7rem; font-weight: 600; padding: 3px 10px; border-radius: 20px; z-index: 2; box-shadow: 0 2px 8px rgba(245,158,11,0.4); }
    .card-destaque { border: 2px solid #f59e0b; }
    .section-title { font-size: 1.3rem; font-weight: 700; color: var(--secundaria); margin-bottom: 1.2rem; padding-bottom: 0.6rem; border-bottom: 3px solid var(--destaque); display: inline-block; }
    .count-badge { background: var(--destaque); color: #fff; font-size: 0.75rem; padding: 1px 8px; border-radius: 20px; margin-left: 6px; }
    footer { background: var(--secundaria); }
    .slides-hero { margin-bottom: 2rem; }
    .slides-hero .carousel-inner { border-radius: 16px; overflow: hidden; box-shadow: 0 4px 24px rgba(0,0,0,0.08); background: #e9ecef; }
    .slides-hero .carousel-item img { width: 100%; max-height: 420px; object-fit: contain; background: #e9ecef; }
    .slides-hero .carousel-item a { display: block; }
    .slides-hero .carousel-caption { background: linear-gradient(transparent, rgba(0,0,0,0.6)); left: 0; right: 0; bottom: 0; padding: 2rem 1.5rem 1.2rem; text-align: left; }
    .slides-hero .carousel-caption h5 { font-weight: 700; font-size: 1.3rem; }
    .slides-hero .carousel-indicators { margin-bottom: 0.5rem; }
    .slides-hero .carousel-indicators button { width: 10px; height: 10px; border-radius: 50%; }
    @media (max-width: 576px) {
      .slides-hero .carousel-item img { max-height: 220px; }
      .slides-hero .carousel-caption h5 { font-size: 0.95rem; }
    }
    @media (max-width: 576px) {
      .hero { padding: 2rem 0 1.8rem; }
      .hero h1 { font-size: 1.5rem; }
      .card-img-top { height: 150px; }
      .card-title { font-size: 0.88rem; }
      .preco { font-size: 1.05rem; }
    }
  </style>
</head>
<body>
  <%- include('partials/topbar') %>
  <nav class="navbar navbar-expand-md navbar-dark navbar-custom">
    <div class="container">
      <a class="navbar-brand fw-bold" href="/"><img src="/images/car-logo.svg" alt="" style="height:28px;width:28px" class="me-1"> <%= nome_site %></a>
      <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target="#menuNav">
        <span class="navbar-toggler-icon"></span>
      </button>
      <div class="collapse navbar-collapse" id="menuNav">
        <ul class="navbar-nav ms-auto">
          <li class="nav-item"><a class="nav-link" href="/ofertas">Ofertas</a></li>
          <li class="nav-item"><a class="nav-link" href="/">Estoque</a></li>
          <li class="nav-item"><a class="nav-link" href="/vender">Venda seu carro</a></li>
          <li class="nav-item"><a class="nav-link" href="/financie">Financie</a></li>
          <li class="nav-item"><a class="nav-link" href="/sobre">Sobre</a></li>
        </ul>
        
      </div>
    </div>
  </nav>

  <section class="hero">
    <div class="container position-relative">
      <div class="row align-items-center">
        <div class="col-lg-7">
          <h1>Encontre o carro ideal para você</h1>
          <p class="lead mb-0">Confira nossa seleção de veículos com os melhores preços do mercado</p>
        </div>
        <div class="col-lg-5 mt-3 mt-lg-0">
          <form method="GET" action="/" class="row g-2">
            <div class="col-12">
              <div class="input-group">
                <span class="input-group-text bg-white border-0"><i class="bi bi-search text-muted"></i></span>
                <input type="text" name="busca" class="form-control" placeholder="Buscar marca ou modelo..." value="<%= filtros.busca || '' %>">
              </div>
            </div>
            <div class="col-6">
              <select name="marca" class="form-select">
                <option value="">Todas as marcas</option>
                <% marcas.forEach(m => { %>
                  <option value="<%= m.marca %>" <%= filtros.marca === m.marca ? 'selected' : '' %>><%= m.marca %></option>
                <% }) %>
              </select>
            </div>
            <div class="col-3">
              <input type="number" name="preco_min" class="form-control" placeholder="R$ min" value="<%= filtros.preco_min || '' %>">
            </div>
            <div class="col-3">
              <button type="submit" class="btn btn-search w-100">Filtrar</button>
            </div>
          </form>
        </div>
      </div>
    </div>
  </section>

  <% const slidesArr = typeof slides === 'string' ? JSON.parse(slides) : (slides || []) %>
  <% const activeSlides = slidesArr.filter(s => s.ativo) %>
  <% if (activeSlides.length > 0) { %>
    <div class="slides-hero">
      <div id="heroSlides" class="carousel slide" data-bs-ride="carousel" data-bs-interval="5000">
        <div class="carousel-indicators">
          <% activeSlides.forEach((s, i) => { %>
            <button type="button" data-bs-target="#heroSlides" data-bs-slide-to="<%= i %>" class="<%= i === 0 ? 'active' : '' %>"></button>
          <% }) %>
        </div>
        <div class="carousel-inner">
          <% activeSlides.forEach((s, i) => { %>
            <div class="carousel-item <%= i === 0 ? 'active' : '' %>">
              <% if (s.link) { %><a href="<%= s.link %>"><% } %>
                <img src="<%= s.imagem %>" class="d-block w-100" alt="<%= s.titulo || '' %>">
                <% if (s.titulo) { %>
                  <div class="carousel-caption d-none d-md-block">
                    <h5><%= s.titulo %></h5>
                  </div>
                <% } %>
              <% if (s.link) { %></a><% } %>
            </div>
          <% }) %>
        </div>
        <button class="carousel-control-prev" type="button" data-bs-target="#heroSlides" data-bs-slide="prev">
          <span class="carousel-control-prev-icon"></span>
        </button>
        <button class="carousel-control-next" type="button" data-bs-target="#heroSlides" data-bs-slide="next">
          <span class="carousel-control-next-icon"></span>
        </button>
      </div>
    </div>
  <% } %>

  <div class="container">
    <div class="d-flex align-items-center justify-content-between mb-3">
      <h2 class="section-title mb-0">
        <i class="bi bi-grid-fill me-1"></i> Estoque
        <span class="count-badge"><%= veiculos.length %></span>
      </h2>
      <% if (filtros.busca || filtros.marca || filtros.preco_min) { %>
        <a href="/" class="btn btn-sm btn-outline-secondary rounded-pill"><i class="bi bi-x-lg"></i> Limpar filtros</a>
      <% } %>
    </div>

    <% if (veiculos.length === 0) { %>
      <div class="text-center py-5">
        <i class="bi bi-car-front" style="font-size: 3rem; color: #ccc;"></i>
        <p class="text-muted mt-2 mb-0">Nenhum veículo encontrado.</p>
        <a href="/" class="btn btn-outline-primary btn-sm mt-2 rounded-pill">Ver todos</a>
      </div>
    <% } %>

    <div class="row g-3">
      <% veiculos.forEach(v => { %>
        <div class="col-6 col-md-4 col-lg-3">
          <div class="card h-100 position-relative <%= v.destaque ? 'card-destaque' : '' %>">
            <% if (v.destaque) { %>
              <span class="badge-destaque"><i class="bi bi-star-fill me-1"></i>Destaque</span>
            <% } %>
            <img src="<%= primeiraImagem(v) || 'https://placehold.co/600x400/e9ecef/999?text=Sem+Imagem' %>" class="card-img-top" alt="<%= v.marca %> <%= v.modelo %>">
            <% if (v.video_url) { %><span class="position-absolute bottom-0 end-0 m-2 bg-dark bg-opacity-75 text-white rounded-pill px-2 py-1 small" style="font-size:11px"><i class="bi bi-play-circle-fill me-1"></i>Vídeo</span><% } %>
            <div class="card-body">
              <h6 class="card-title"><%= v.marca %> <%= v.modelo %></h6>
              <div class="card-meta">
                <i class="bi bi-calendar"></i> <%= v.ano_fabricacao %>/<%= v.ano_modelo %> &bull;
                <i class="bi bi-speedometer2"></i> <%= v.quilometragem.toLocaleString() %> km
              </div>
              <div class="preco">R$ <%= v.preco.toLocaleString('pt-BR', { minimumFractionDigits: 2 }) %></div>
              <div class="tag-group">
                <span class="tag tag-cambio"><i class="bi bi-gear me-1"></i><%= v.cambio %></span>
                <span class="tag tag-cor"><i class="bi bi-palette me-1"></i><%= v.cor %></span>
                <span class="tag tag-portas"><i class="bi bi-car-front me-1"></i><%= v.portas %>p</span>
              </div>
            </div>
            <div class="card-footer">
              <a href="/veiculo/<%= v.id %>" class="btn btn-primary w-100"><i class="bi bi-eye me-1"></i> Detalhes</a>
            </div>
          </div>
        </div>
      <% }) %>
    </div>
  </div>

  <footer class="text-white text-center py-4 mt-5">
    <small>&copy; <%= new Date().getFullYear() %> <%= nome_site %>. Todos os direitos reservados.</small>
  </footer>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
